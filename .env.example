# ── Database ──
DATABASE_URL="postgresql://user:password@localhost:5433/launchpromptly?schema=public"

# ── API Server ──
API_PORT=3001
CORS_ORIGIN="http://localhost:3000"
APP_URL="http://localhost:3000"

# ── Authentication ──
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="change-me-in-production"

# ── Encryption (AES-256-GCM for provider API keys at rest) ──
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=""

# ── LLM Provider (LaunchPromptly bundled credits for evals & playground) ──
ANTHROPIC_API_KEY=""

# ── Billing (Lemon Squeezy — optional) ──
LS_STORE_ID=""
LS_WEBHOOK_SECRET=""
LS_VARIANT_PRO=""
LS_VARIANT_TEAM=""

# ── Frontend ──
NEXT_PUBLIC_API_URL="http://localhost:3001"
