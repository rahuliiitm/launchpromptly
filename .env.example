# ── Database ──
DATABASE_URL="postgresql://launchpromptly:launchpromptly@localhost:5433/launchpromptly?schema=public"

# ── API Server ──
API_PORT=3001
CORS_ORIGIN="http://localhost:3000"
APP_URL="http://localhost:3000"

# ── Authentication ──
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="change-me-in-production"

# ── Encryption (AES-256-GCM for provider API keys at rest) ──
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=""

# ── Billing (Lemon Squeezy — optional) ──
LS_STORE_ID=""
LS_WEBHOOK_SECRET=""
LS_VARIANT_PRO=""
LS_VARIANT_TEAM=""

# ── Error Monitoring (Sentry — optional) ──
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""

# ── Product Analytics (PostHog — optional) ──
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"

# ── Email (password reset — optional, uses Resend) ──
RESEND_API_KEY=""
EMAIL_FROM="noreply@launchpromptly.dev"

# ── Frontend ──
NEXT_PUBLIC_API_URL="http://localhost:3001"
