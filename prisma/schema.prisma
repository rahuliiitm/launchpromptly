generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String        @id @default(uuid())
  email          String        @unique
  passwordHash   String?
  organizationId String?
  role           String        @default("admin")
  createdAt      DateTime      @default(now())
  organization   Organization? @relation(fields: [organizationId], references: [id])
}

model Organization {
  id                    String           @id @default(uuid())
  name                  String
  plan                  String           @default("free")
  lsCustomerId          String?
  lsSubscriptionId      String?
  lsSubscriptionStatus  String?
  lsVariantId           String?
  planExpiresAt         DateTime?
  createdAt             DateTime         @default(now())
  users                 User[]
  projects              Project[]
  providerKeys          OrgProviderKey[]
  invitations           Invitation[]
}

model OrgProviderKey {
  id             String       @id @default(uuid())
  organizationId String
  provider       String
  encryptedKey   String
  iv             String
  authTag        String
  label          String       @default("Default")
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, provider])
  @@index([organizationId])
}

model Project {
  id              String           @id @default(uuid())
  organizationId  String
  name            String
  createdAt       DateTime         @default(now())
  organization    Organization     @relation(fields: [organizationId], references: [id])
  apiKeys         ApiKey[]
  events          LLMEvent[]
  managedPrompts  ManagedPrompt[]
  environments    Environment[]

  @@index([organizationId])
}

model ApiKey {
  id            String       @id @default(uuid())
  projectId     String
  environmentId String?
  keyHash       String       @unique
  keyPrefix     String
  name          String       @default("Default")
  createdAt     DateTime     @default(now())
  lastUsedAt    DateTime?
  revokedAt     DateTime?
  project       Project      @relation(fields: [projectId], references: [id])
  environment   Environment? @relation(fields: [environmentId], references: [id])

  @@index([keyHash])
}

model LLMEvent {
  id              String         @id @default(uuid())
  projectId       String
  customerId      String?
  feature         String?
  provider        String
  model           String
  inputTokens     Int
  outputTokens    Int
  totalTokens     Int
  costUsd         Float
  latencyMs       Int
  systemHash      String?
  fullHash        String?
  promptPreview   String?
  statusCode      Int            @default(200)
  managedPromptId  String?
  promptVersionId  String?
  ragPipelineId    String?
  ragQuery         String?
  ragRetrievalMs   Int?
  ragChunkCount    Int?
  ragContextTokens Int?
  ragChunks        Json?
  responseText     String?
  traceId          String?
  spanName         String?
  environmentId    String?
  createdAt        DateTime       @default(now())
  project          Project        @relation(fields: [projectId], references: [id])
  managedPrompt    ManagedPrompt? @relation(fields: [managedPromptId], references: [id])
  promptVersion    PromptVersion? @relation("VersionEvents", fields: [promptVersionId], references: [id])
  ragEvaluation    RagEvaluation?

  @@index([projectId, createdAt])
  @@index([projectId, customerId])
  @@index([projectId, systemHash])
  @@index([projectId, feature])
  @@index([projectId, model])
  @@index([projectId, managedPromptId])
  @@index([projectId, ragPipelineId])
  @@index([projectId, traceId])
  @@index([projectId, environmentId, managedPromptId])
}

model RagEvaluation {
  id                        String   @id @default(uuid())
  eventId                   String   @unique
  faithfulnessScore         Float?
  faithfulnessReasoning     String?
  relevanceScore            Float?
  relevanceReasoning        String?
  contextRelevanceScore     Float?
  contextRelevanceReasoning String?
  chunkRelevanceScores      Json?
  evaluationModel           String
  evaluationCostUsd         Float    @default(0)
  status                    String   @default("completed")
  error                     String?
  createdAt                 DateTime @default(now())
  event                     LLMEvent @relation(fields: [eventId], references: [id])
}

model ManagedPrompt {
  id               String          @id @default(uuid())
  projectId        String
  slug             String
  name             String
  description      String          @default("")
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  project          Project              @relation(fields: [projectId], references: [id])
  versions         PromptVersion[]
  abTests          ABTest[]
  events           LLMEvent[]
  deployments      PromptDeployment[]

  @@unique([projectId, slug])
  @@index([projectId])
}

model PromptVersion {
  id              String          @id @default(uuid())
  managedPromptId String
  version         Int
  content         String
  status          String          @default("draft")
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  managedPrompt   ManagedPrompt        @relation(fields: [managedPromptId], references: [id], onDelete: Cascade)
  abTestVariants  ABTestVariant[]
  events          LLMEvent[]           @relation("VersionEvents")
  deployments     PromptDeployment[]

  @@unique([managedPromptId, version])
  @@index([managedPromptId, status])
}

model ABTest {
  id              String          @id @default(uuid())
  managedPromptId String
  name            String
  status          String          @default("draft")
  startedAt       DateTime?
  completedAt     DateTime?
  createdAt       DateTime        @default(now())
  managedPrompt   ManagedPrompt   @relation(fields: [managedPromptId], references: [id], onDelete: Cascade)
  variants        ABTestVariant[]

  @@index([managedPromptId, status])
}

model ABTestVariant {
  id              String        @id @default(uuid())
  abTestId        String
  promptVersionId String
  trafficPercent  Int
  abTest          ABTest        @relation(fields: [abTestId], references: [id], onDelete: Cascade)
  promptVersion   PromptVersion @relation(fields: [promptVersionId], references: [id])

  @@unique([abTestId, promptVersionId])
}

model Invitation {
  id             String       @id @default(uuid())
  organizationId String
  email          String
  role           String       @default("member")
  token          String       @unique
  invitedById    String
  expiresAt      DateTime
  acceptedAt     DateTime?
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, email])
  @@index([organizationId])
}

model Environment {
  id          String              @id @default(uuid())
  projectId   String
  name        String
  slug        String
  color       String              @default("#6B7280")
  sortOrder   Int                 @default(0)
  isCritical  Boolean             @default(false)
  createdAt   DateTime            @default(now())
  project     Project             @relation(fields: [projectId], references: [id])
  apiKeys     ApiKey[]
  deployments PromptDeployment[]

  @@unique([projectId, slug])
  @@index([projectId])
}

model PromptDeployment {
  id              String        @id @default(uuid())
  managedPromptId String
  environmentId   String
  promptVersionId String
  deployedAt      DateTime      @default(now())
  deployedBy      String?
  managedPrompt   ManagedPrompt @relation(fields: [managedPromptId], references: [id], onDelete: Cascade)
  environment     Environment   @relation(fields: [environmentId], references: [id])
  promptVersion   PromptVersion @relation(fields: [promptVersionId], references: [id])

  @@unique([managedPromptId, environmentId])
  @@index([environmentId])
}
