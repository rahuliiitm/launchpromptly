generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String        @id @default(uuid())
  email          String        @unique
  passwordHash   String?
  organizationId String?
  role           String        @default("admin")
  createdAt      DateTime      @default(now())
  scenarios      Scenario[]
  organization   Organization? @relation(fields: [organizationId], references: [id])
}

model Organization {
  id           String           @id @default(uuid())
  name         String
  plan         String           @default("free")
  createdAt    DateTime         @default(now())
  users        User[]
  projects     Project[]
  providerKeys OrgProviderKey[]
  invitations  Invitation[]
}

model OrgProviderKey {
  id             String       @id @default(uuid())
  organizationId String
  provider       String
  encryptedKey   String
  iv             String
  authTag        String
  label          String       @default("Default")
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, provider])
  @@index([organizationId])
}

model Project {
  id              String           @id @default(uuid())
  organizationId  String
  name            String
  createdAt       DateTime         @default(now())
  organization    Organization     @relation(fields: [organizationId], references: [id])
  apiKeys         ApiKey[]
  events          LLMEvent[]
  managedPrompts  ManagedPrompt[]

  @@index([organizationId])
}

model ApiKey {
  id         String    @id @default(uuid())
  projectId  String
  keyHash    String    @unique
  keyPrefix  String
  name       String    @default("Default")
  createdAt  DateTime  @default(now())
  lastUsedAt DateTime?
  revokedAt  DateTime?
  project    Project   @relation(fields: [projectId], references: [id])

  @@index([keyHash])
}

model LLMEvent {
  id              String         @id @default(uuid())
  projectId       String
  customerId      String?
  feature         String?
  provider        String
  model           String
  inputTokens     Int
  outputTokens    Int
  totalTokens     Int
  costUsd         Float
  latencyMs       Int
  systemHash      String?
  fullHash        String?
  promptPreview   String?
  statusCode      Int            @default(200)
  managedPromptId  String?
  promptVersionId  String?
  ragPipelineId    String?
  ragQuery         String?
  ragRetrievalMs   Int?
  ragChunkCount    Int?
  ragContextTokens Int?
  ragChunks        Json?
  createdAt        DateTime       @default(now())
  project          Project        @relation(fields: [projectId], references: [id])
  managedPrompt    ManagedPrompt? @relation(fields: [managedPromptId], references: [id])
  promptVersion    PromptVersion? @relation("VersionEvents", fields: [promptVersionId], references: [id])

  @@index([projectId, createdAt])
  @@index([projectId, customerId])
  @@index([projectId, systemHash])
  @@index([projectId, feature])
  @@index([projectId, model])
  @@index([projectId, managedPromptId])
  @@index([projectId, ragPipelineId])
}

model ManagedPrompt {
  id               String          @id @default(uuid())
  projectId        String
  slug             String
  name             String
  description      String          @default("")
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  project          Project         @relation(fields: [projectId], references: [id])
  versions         PromptVersion[]
  abTests          ABTest[]
  events           LLMEvent[]

  @@unique([projectId, slug])
  @@index([projectId])
}

model PromptVersion {
  id              String          @id @default(uuid())
  managedPromptId String
  version         Int
  content         String
  status          String          @default("draft")
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  managedPrompt   ManagedPrompt   @relation(fields: [managedPromptId], references: [id], onDelete: Cascade)
  abTestVariants  ABTestVariant[]
  events          LLMEvent[]      @relation("VersionEvents")

  @@unique([managedPromptId, version])
  @@index([managedPromptId, status])
}

model ABTest {
  id              String          @id @default(uuid())
  managedPromptId String
  name            String
  status          String          @default("draft")
  startedAt       DateTime?
  completedAt     DateTime?
  createdAt       DateTime        @default(now())
  managedPrompt   ManagedPrompt   @relation(fields: [managedPromptId], references: [id], onDelete: Cascade)
  variants        ABTestVariant[]

  @@index([managedPromptId, status])
}

model ABTestVariant {
  id              String        @id @default(uuid())
  abTestId        String
  promptVersionId String
  trafficPercent  Int
  abTest          ABTest        @relation(fields: [abTestId], references: [id], onDelete: Cascade)
  promptVersion   PromptVersion @relation(fields: [promptVersionId], references: [id])

  @@unique([abTestId, promptVersionId])
}

model Invitation {
  id             String       @id @default(uuid())
  organizationId String
  email          String
  role           String       @default("member")
  token          String       @unique
  invitedById    String
  expiresAt      DateTime
  acceptedAt     DateTime?
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, email])
  @@index([organizationId])
}

model Scenario {
  id                String     @id @default(uuid())
  userId            String
  name              String
  model             String
  avgInputTokens    Int
  avgOutputTokens   Int
  requestsPerUser   Int
  projectedUsers    Int
  subscriptionPrice Float
  createdAt         DateTime   @default(now())
  user              User       @relation(fields: [userId], references: [id])
  snapshots         Snapshot[]
}

model Snapshot {
  id                String   @id @default(uuid())
  scenarioId        String
  label             String
  model             String
  avgInputTokens    Int
  avgOutputTokens   Int
  requestsPerUser   Int
  projectedUsers    Int
  subscriptionPrice Float
  createdAt         DateTime @default(now())
  scenario          Scenario @relation(fields: [scenarioId], references: [id])

  @@index([scenarioId])
}
