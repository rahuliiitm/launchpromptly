generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                    String        @id @default(uuid())
  email                 String        @unique
  passwordHash          String?
  organizationId        String?
  role                  String        @default("admin")
  passwordResetToken    String?       @unique
  passwordResetExpires  DateTime?
  createdAt             DateTime      @default(now())
  organization          Organization? @relation(fields: [organizationId], references: [id])
}

model Organization {
  id                    String           @id @default(uuid())
  name                  String
  plan                  String           @default("free")
  lsCustomerId          String?
  lsSubscriptionId      String?
  lsSubscriptionStatus  String?
  lsVariantId           String?
  planExpiresAt         DateTime?
  createdAt             DateTime         @default(now())
  users                 User[]
  projects              Project[]
  providerKeys          OrgProviderKey[]
  invitations           Invitation[]
}

model OrgProviderKey {
  id             String       @id @default(uuid())
  organizationId String
  provider       String
  encryptedKey   String
  iv             String
  authTag        String
  label          String       @default("Default")
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, provider])
  @@index([organizationId])
}

model Project {
  id               String             @id @default(uuid())
  organizationId   String
  name             String
  createdAt        DateTime           @default(now())
  organization     Organization       @relation(fields: [organizationId], references: [id])
  retentionDays    Int                @default(90)
  apiKeys          ApiKey[]
  events           LLMEvent[]
  environments     Environment[]
  auditLogs        AuditLog[]
  securityPolicies SecurityPolicy[]
  alertRules       AlertRule[]

  @@index([organizationId])
}

model ApiKey {
  id            String       @id @default(uuid())
  projectId     String
  environmentId String?
  keyHash       String       @unique
  keyPrefix     String
  name          String       @default("Default")
  createdAt     DateTime     @default(now())
  lastUsedAt    DateTime?
  revokedAt     DateTime?
  expiresAt     DateTime?
  project       Project      @relation(fields: [projectId], references: [id])
  environment   Environment? @relation(fields: [environmentId], references: [id])

  @@index([keyHash])
}

model LLMEvent {
  id              String         @id @default(uuid())
  projectId       String
  customerId      String?
  feature         String?
  provider        String
  model           String
  inputTokens     Int
  outputTokens    Int
  totalTokens     Int
  costUsd         Float
  latencyMs       Int
  systemHash      String?
  fullHash        String?
  promptPreview   String?
  statusCode      Int            @default(200)
  responseText     String?
  traceId          String?
  spanName         String?
  environmentId    String?
  metadata         Json?
  createdAt        DateTime       @default(now())

  // Security metadata (from SDK security pipeline)
  piiDetectionCount   Int?
  piiTypes            String[]     @default([])
  injectionRiskScore  Float?
  injectionAction     String?
  redactionApplied    Boolean      @default(false)
  securityMetadata    Json?

  // Encrypted fields (AES-256-GCM via CryptoService)
  encPromptPreview    String?
  encResponseText     String?
  encIv               String?
  encAuthTag          String?

  project          Project        @relation(fields: [projectId], references: [id])

  @@index([projectId, createdAt])
  @@index([projectId, customerId])
  @@index([projectId, systemHash])
  @@index([projectId, feature])
  @@index([projectId, model])
  @@index([projectId, traceId])
  @@index([projectId, injectionRiskScore])
  @@index([projectId, redactionApplied])
}

model Invitation {
  id             String       @id @default(uuid())
  organizationId String
  email          String
  role           String       @default("member")
  token          String       @unique
  invitedById    String
  expiresAt      DateTime
  acceptedAt     DateTime?
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, email])
  @@index([organizationId])
}

model Environment {
  id          String              @id @default(uuid())
  projectId   String
  name        String
  slug        String
  color       String              @default("#6B7280")
  sortOrder   Int                 @default(0)
  isCritical      Boolean             @default(false)
  createdAt       DateTime            @default(now())
  project     Project             @relation(fields: [projectId], references: [id])
  apiKeys     ApiKey[]

  @@unique([projectId, slug])
  @@index([projectId])
}

model AuditLog {
  id          String   @id @default(uuid())
  projectId   String
  eventType   String
  severity    String   @default("info")
  details     Json
  eventId     String?
  customerId  String?
  actorId     String?
  createdAt   DateTime @default(now())
  project     Project  @relation(fields: [projectId], references: [id])

  @@index([projectId, createdAt])
  @@index([projectId, eventType])
  @@index([projectId, severity])
}

model SecurityPolicy {
  id          String   @id @default(uuid())
  projectId   String
  name        String
  description String   @default("")
  rules       Json
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  project     Project  @relation(fields: [projectId], references: [id])

  @@unique([projectId, name])
  @@index([projectId, isActive])
}

model AlertRule {
  id              String   @id @default(uuid())
  projectId       String
  name            String
  condition       Json
  channel         String   @default("webhook")
  webhookUrl      String?
  email           String?
  throttleMinutes Int      @default(60)
  enabled         Boolean  @default(true)
  lastFiredAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  project         Project  @relation(fields: [projectId], references: [id])

  @@index([projectId, enabled])
}
